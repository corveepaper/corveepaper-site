# Netlify _headers — applied to every response served.
# Reference: https://docs.netlify.com/routing/headers/

# ── Default policy for every path ─────────────────────────────────────────────
/*
  # Force HTTPS for 1 year, all subdomains, preload-ready.
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Block clickjacking (legacy header — covered by CSP frame-ancestors too).
  X-Frame-Options: DENY

  # Don't let browsers guess content types (e.g. interpret a .txt as JS).
  X-Content-Type-Options: nosniff

  # Send only the origin to other sites, never a full path.
  Referrer-Policy: strict-origin-when-cross-origin

  # Disable browser APIs we never use (defense-in-depth against injected code).
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=(), interest-cohort=()

  # Content Security Policy — controls what the page can load.
  # - script-src: our own JS + React from unpkg + Umami cloud (analytics).
  # - style-src 'unsafe-inline': required because the JSX uses inline style={}.
  # - font-src: Google Fonts CDN.
  # - img-src: own assets, base64 inlined SVG, and https for OG image previews.
  # - connect-src: where the JS may fetch from (Umami sends pageviews here).
  # - form-action: the contact form will POST to Formspree.
  # - frame-ancestors 'none': nobody can <iframe> us.
  Content-Security-Policy: default-src 'self'; script-src 'self' https://unpkg.com https://cloud.umami.is; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://cloud.umami.is https://formspree.io; form-action 'self' https://formspree.io; frame-src 'self'; frame-ancestors 'none'; base-uri 'self'; object-src 'none'

  # Cross-Origin policies — modern hardening.
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-site

# ── Portfolio concept sites (/portfolio/*) ───────────────────────────────────
# These are static HTML/CSS demos that legitimately use inline <script> blocks
# (scroll-reveal animations) and inline on* handlers (form feedback). The main
# site's strict CSP (script-src 'self' only) would block them, so we override
# the CSP for this subtree ONLY. On Netlify, a more specific path REPLACES the
# same header from /*, so the studio keeps its stricter policy untouched.
# All other security headers are re-declared here so nothing is lost.
/portfolio/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'; form-action 'self'; frame-ancestors 'self'; base-uri 'self'; object-src 'none'
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-site

# ── Long cache for fingerprinted-style static assets ─────────────────────────
# (No fingerprinting yet — these are short-cache hints. Tighten later when
# you start versioning JS filenames.)
/*.svg
  Cache-Control: public, max-age=86400, must-revalidate

/*.png
  Cache-Control: public, max-age=86400, must-revalidate

/js/*
  # Always revalidate JS so a new deploy is picked up immediately (no stale
  # cached bundle). Cheap for a small site; pairs with the ?v= cache-buster
  # on the <script> tags in index.html.
  Cache-Control: public, max-age=0, must-revalidate

# ── HTML always revalidated so deploys show immediately ──────────────────────
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate
